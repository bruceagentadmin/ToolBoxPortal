{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "outDir": "dist/renderer",
    "declaration": true,
    "composite": true
  },
  "include": [
    "app/renderer/src/**/*.ts",
    "app/renderer/src/**/*.tsx",
    "app/shared/**/*.ts"
  ]
}
