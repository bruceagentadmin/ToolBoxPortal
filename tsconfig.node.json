{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "dist",
    "declaration": true,
    "composite": true,
    "types": ["node"]
  },
  "include": [
    "app/main/**/*.ts",
    "app/preload/**/*.ts",
    "app/shared/**/*.ts",
    "electron.vite.config.ts"
  ]
}
